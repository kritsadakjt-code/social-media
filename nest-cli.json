{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/social-backend/src",
  "compilerOptions": {
    "assets": ["**/*.proto"],
    "watchAssets": true,
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/social-backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/social-backend",
  "projects": {
    "feed-service": {
      "type": "application",
      "root": "apps/feed-service",
      "entryFile": "main",
      "sourceRoot": "apps/feed-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/feed-service/tsconfig.app.json"
      }
    },
    "follow-service": {
      "type": "application",
      "root": "apps/follow-service",
      "entryFile": "main",
      "sourceRoot": "apps/follow-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/follow-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    },
    "post-service": {
      "type": "application",
      "root": "apps/post-service",
      "entryFile": "main",
      "sourceRoot": "apps/post-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/post-service/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "social-backend": {
      "type": "application",
      "root": "apps/social-backend",
      "entryFile": "main",
      "sourceRoot": "apps/social-backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/social-backend/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    }
  }
}
